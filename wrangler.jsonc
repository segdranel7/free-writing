{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "free-writing-translation",
  "main": "workers/translation/index.ts",
  "compatibility_date": "2026-05-14",
  "workers_dev": true,
  "preview_urls": false,
  "vars": {
    "ALLOWED_ORIGINS": "http://localhost:5173,http://127.0.0.1:5173,https://free-writing-e29a1.web.app,https://free-writing-e29a1.firebaseapp.com"
  },
  "secrets": {
    "required": ["GROQ_API_KEY", "FIREBASE_API_KEY"]
  }
}
