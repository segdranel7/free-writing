VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Optional: point the browser at a deployed translation endpoint.
# Free hosted production should use the Cloudflare Worker URL.
VITE_TRANSLATION_API_URL=

# Do not put GROQ_API_KEY in browser-exposed VITE_ variables.
# For Cloudflare Worker local testing, copy .dev.vars.example to .dev.vars.
# For local Vite-only testing, you may put GROQ_API_KEY in your ignored .env.
